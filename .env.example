# ══════════════════════════════════════════════════════════════
# Fingerprint Worker — Environment Variables (Jetson Nano)
# ══════════════════════════════════════════════════════════════

# ── Worker Identity ─────────────────────────────────────────
WORKER_ID=jetson-nano-01

# ── MQTT / Mosquitto ────────────────────────────────────────
MQTT_BROKER_HOST=<IP Broker>
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_KEEPALIVE=60
MQTT_RECONNECT_DELAY=5

# ── Heartbeat ───────────────────────────────────────────────
HEARTBEAT_INTERVAL=10
